# ============================================================
# Polyglot AI Studio — Production Environment
# Copy this file to the server and fill in the real values.
# NEVER commit a file with real credentials to git.
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Option A: Neon.tech (or any managed PostgreSQL)
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL_OVERRIDE=postgresql://username:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Option B: Self-hosted PostgreSQL (comment out DATABASE_URL_OVERRIDE above)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=polyglot_ai
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change_me

# ── Security ─────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── File uploads ─────────────────────────────────────────────
UPLOAD_DIRECTORY=app/uploads
MAX_UPLOAD_SIZE_MB=20

# ── CORS ─────────────────────────────────────────────────────
# Set to your Vercel frontend URL (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# ── Email via Resend (optional) ──────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Polyglot AI Studio
